# Copiar a .env y ajustar valores si es necesario.
# .env está en .gitignore — nunca commitear credenciales reales.

# URL base de la instancia OSSN a testear.
# Por defecto: demo pública. Si está bloqueada por Cloudflare,
# apuntar a una instancia local (ej: Docker) o alternativa.
# Ver README § Limitaciones conocidas para más detalles.
BASE_URL=https://demo.opensource-socialnetwork.org

# Credenciales de usuario demo
DEMO_USERNAME=administrator
DEMO_PASSWORD=administrator
